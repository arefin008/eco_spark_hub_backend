<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reset Password</title>
    <style>
      body { font-family: Arial, sans-serif; background: #f4f7fb; padding: 24px; color: #132a13; }
      .card { max-width: 560px; margin: 0 auto; background: #fff; border-radius: 12px; padding: 24px; border: 1px solid #e4ebe4; }
      .brand { color: #2d6a4f; font-weight: 700; font-size: 20px; margin-bottom: 8px; }
      .btn { display: inline-block; margin-top: 14px; background: #1d3557; color: #fff !important; text-decoration: none; padding: 12px 18px; border-radius: 8px; }
      .hint { color: #4f5d75; font-size: 13px; margin-top: 16px; }
    </style>
  </head>
  <body>
    <div class="card">
      <div class="brand">EcoSpark Hub</div>
      <h2>Reset your password</h2>
      <p>Hello <b><%= name %></b>,</p>
      <p>Click the button below to reset your password:</p>
      <a href="<%= resetUrl %>" class="btn">Reset Password</a>
      <p class="hint">If you did not request this, please ignore this email.</p>
    </div>
  </body>
</html>
