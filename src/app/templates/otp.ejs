<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <style>
      body { font-family: Arial, sans-serif; background: #f4f7fb; padding: 24px; color: #132a13; }
      .card { max-width: 560px; margin: 0 auto; background: #fff; border-radius: 12px; padding: 24px; border: 1px solid #e4ebe4; }
      .brand { color: #2d6a4f; font-weight: 700; font-size: 20px; margin-bottom: 8px; }
      .otp { font-size: 34px; letter-spacing: 8px; font-weight: 700; color: #1b4332; margin: 20px 0; }
      .hint { color: #4f5d75; font-size: 14px; }
    </style>
  </head>
  <body>
    <div class="card">
      <div class="brand">EcoSpark Hub</div>
      <h2><%= heading %></h2>
      <p>Hello <b><%= name %></b>,</p>
      <p>Use the OTP below to continue:</p>
      <div class="otp"><%= otp %></div>
      <p class="hint">This code expires in <%= expiresInMinutes %> minutes. Do not share it with anyone.</p>
    </div>
  </body>
</html>
